{
  "name": "mixlab-oidc-next",
  "version": "0.1.0",
  "description": "MixLab OIDC SDK for Next.js — login in 10 minutes.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/provider.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js",
      "require": "./dist/proxy.cjs"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js",
      "require": "./dist/sanitize.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mixlab-oidc-next": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "changeset": "changeset",
    "release": "changeset version && pnpm build && changeset publish"
  },
  "peerDependencies": {
    "next": "^14.2.0 || ^15.0.0 || ^16.0.0",
    "next-auth": "^5.0.0-beta.20"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": true
    }
  },
  "dependencies": {
    "iron-session": "^8.0.4",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^2.1.8",
    "commander": "^15.0.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.8"
  }
}
